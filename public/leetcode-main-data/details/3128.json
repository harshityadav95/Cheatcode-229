arkreader-inline-border-left: #8c8273;\">0</td>\n\t\t\t<td data-darkreader-inline-border-bottom=\"\" data-darkreader-inline-border-left=\"\" data-darkreader-inline-border-right=\"\" data-darkreader-inline-border-top=\"\" style=\"padding: 5px 10px; border: 1px solid silver; --darkreader-inline-border-top: #8c8273; --darkreader-inline-border-right: #8c8273; --darkreader-inline-border-bottom: #8c8273; --darkreader-inline-border-left: #8c8273;\">0</td>\n\t\t</tr>\n\t</tbody>\n</table>\n\n<table border=\"1\" cellspacing=\"3\" style=\"border-collapse: separate; text-align: center;\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<td data-darkreader-inline-border-bottom=\"\" data-darkreader-inline-border-left=\"\" data-darkreader-inline-border-right=\"\" data-darkreader-inline-border-top=\"\" style=\"padding: 5px 10px; border: 1px solid red; --darkreader-inline-border-top: #b30000; --darkreader-inline-border-right: #b30000; --darkreader-inline-border-bottom: #b30000; --darkreader-inline-border-left: #b30000;\">1</td>\n\t\t\t<td data-darkreader-inline-border-bottom=\"\" data-darkreader-inline-border-left=\"\" data-darkreader-inline-border-right=\"\" data-darkreader-inline-border-top=\"\" style=\"padding: 5px 10px; border: 1px solid silver; --darkreader-inline-border-top: #8c8273; --darkreader-inline-border-right: #8c8273; --darkreader-inline-border-bottom: #8c8273; --darkreader-inline-border-left: #8c8273;\">0</td>\n\t\t\t<td data-darkreader-inline-border-bottom=\"\" data-darkreader-inline-border-left=\"\" data-darkreader-inline-border-right=\"\" data-darkreader-inline-border-top=\"\" style=\"padding: 5px 10px; border: 1px solid red; --darkreader-inline-border-top: #b30000; --darkreader-inline-border-right: #b30000; --darkreader-inline-border-bottom: #b30000; --darkreader-inline-border-left: #b30000;\">1</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td data-darkreader-inline-border-bottom=\"\" data-darkreader-inline-border-left=\"\" data-darkreader-inline-border-right=\"\" data-darkreader-inline-border-top=\"\" style=\"padding: 5px 10px; border: 1px solid silver; --darkreader-inline-border-top: #8c8273; --darkreader-inline-border-right: #8c8273; --darkreader-inline-border-bottom: #8c8273; --darkreader-inline-border-left: #8c8273;\">1</td>\n\t\t\t<td data-darkreader-inline-border-bottom=\"\" data-darkreader-inline-border-left=\"\" data-darkreader-inline-border-right=\"\" data-darkreader-inline-border-top=\"\" style=\"padding: 5px 10px; border: 1px solid silver; --darkreader-inline-border-top: #8c8273; --darkreader-inline-border-right: #8c8273; --darkreader-inline-border-bottom: #8c8273; --darkreader-inline-border-left: #8c8273;\">0</td>\n\t\t\t<td data-darkreader-inline-border-bottom=\"\" data-darkreader-inline-border-left=\"\" data-darkreader-inline-border-right=\"\" data-darkreader-inline-border-top=\"\" style=\"padding: 5px 10px; border: 1px solid silver; --darkreader-inline-border-top: #8c8273; --darkreader-inline-border-right: #8c8273; --darkreader-inline-border-bottom: #8c8273; --darkreader-inline-border-left: #8c8273;\">0</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td data-darkreader-inline-border-bottom=\"\" data-darkreader-inline-border-left=\"\" data-darkreader-inline-border-right=\"\" data-darkreader-inline-border-top=\"\" style=\"padding: 5px 10px; border: 1px solid red; --darkreader-inline-border-top: #b30000; --darkreader-inline-border-right: #b30000; --darkreader-inline-border-bottom: #b30000; --darkreader-inline-border-left: #b30000;\">1</td>\n\t\t\t<td data-darkreader-inline-border-bottom=\"\" data-darkreader-inline-border-left=\"\" data-darkreader-inline-border-right=\"\" data-darkreader-inline-border-top=\"\" style=\"padding: 5px 10px; border: 1px solid silver; --darkreader-inline-border-top: #8c8273; --darkreader-inline-border-right: #8c8273; --darkreader-inline-border-bottom: #8c8273; --darkreader-inline-border-left: #8c8273;\">0</td>\n\t\t\t<td data-darkreader-inline-border-bottom=\"\" data-darkreader-inline-border-left=\"\" data-darkreader-inline-border-right=\"\" data-darkreader-inline-border-top=\"\" style=\"padding: 5px 10px; border: 1px solid silver; --darkreader-inline-border-top: #8c8273; --darkreader-inline-border-right: #8c8273; --darkreader-inline-border-bottom: #8c8273; --darkreader-inline-border-left: #8c8273;\">0</td>\n\t\t</tr>\n\t</tbody>\n</table>\n</div>\n\n<div class=\"example-block\">\n<p><strong>Input:</strong> <span class=\"example-io\">grid = [[1,0,1],[1,0,0],[1,0,0]]</span></p>\n\n<p><strong>Output: </strong>2</p>\n\n<p><strong>Explanation:</strong></p>\n\n<p>There are two right triangles with elements of the value 1.</p>\n</div>\n\n<p>&nbsp;</p>\n<p><strong>Constraints:</strong></p>\n\n<ul>\n\t<li><code>1 &lt;= grid.length &lt;= 1000</code></li>\n\t<li><code>1 &lt;= grid[i].length &lt;= 1000</code></li>\n\t<li><code>0 &lt;= grid[i][j] &lt;= 1</code></li>\n</ul>","solutionText":"Solution 1: Counting + Enumeration\n\nFirst, we can count the number of $1$s in each row and each column, and record them in the arrays $rows$ and $cols$.\n\nThen, we enumerate each $1$. Suppose the current $1$ is in the $i$-th row and the $j$-th column. If we take this $1$ as the right angle of a right triangle, the other two right angles are in the $i$-th row and the $j$-th column. Therefore, the number of right triangles is $(rows[i] - 1) \\times (cols[j] - 1)$. We add this to the total count.\n\nThe time complexity is $O(m \\times n)$, and the space complexity is $O(m + n)$. Where $m$ and $n$ are the number of rows and columns in the matrix, respectively.","solutionMarkdown":"<!-- solution:start -->\n\n### Solution 1: Counting + Enumeration\n\nFirst, we can count the number of $1$s in each row and each column, and record them in the arrays $rows$ and $cols$.\n\nThen, we enumerate each $1$. Suppose the current $1$ is in the $i$-th row and the $j$-th column. If we take this $1$ as the right angle of a right triangle, the other two right angles are in the $i$-th row and the $j$-th column. Therefore, the number of right triangles is $(rows[i] - 1) \\times (cols[j] - 1)$. We add this to the total count.\n\nThe time complexity is $O(m \\times n)$, and the space complexity is $O(m + n)$. Where $m$ and $n$ are the number of rows and columns in the matrix, respectively.\n\n<!-- tabs:start -->\n\n#### Python3\n\n```python\nclass Solution:\n    def numberOfRightTriangles(self, grid: List[List[int]]) -> int:\n        rows = [0] * len(grid)\n        cols = [0] * len(grid[0])\n        for i, row in enumerate(grid):\n            for j, x in enumerate(row):\n                rows[i] += x\n                cols[j] += x\n        ans = 0\n        for i, row in enumerate(grid):\n            for j, x in enumerate(row):\n                if x:\n                    ans += (rows[i] - 1) * (cols[j] - 1)\n        return ans\n```\n\n#### Java\n\n```java\nclass Solution {\n    public long numberOfRightTriangles(int[][] grid) {\n        int m = grid.length, n = grid[0].length;\n        int[] rows = new int[m];\n        int[] cols = new int[n];\n        for (int i = 0; i < m; ++i) {\n            for (int j = 0; j < n; ++j) {\n                rows[i] += grid[i][j];\n                cols[j] += grid[i][j];\n            }\n        }\n        long ans = 0;\n        for (int i = 0; i < m; ++i) {\n            for (int j = 0; j < n; ++j) {\n                if (grid[i][j] == 1) {\n                    ans += (rows[i] - 1) * (cols[j] - 1);\n                }\n            }\n        }\n        return ans;\n    }\n}\n```\n\n#### C++\n\n```cpp\nclass Solution {\npublic:\n    long long numberOfRightTriangles(vector<vector<int>>& grid) {\n        int m = grid.size(), n = grid[0].size();\n        vector<int> rows(m);\n        vector<int> cols(n);\n        for (int i = 0; i < m; ++i) {\n            for (int j = 0; j < n; ++j) {\n                rows[i] += grid[i][j];\n                cols[j] += grid[i][j];\n            }\n        }\n        long long ans = 0;\n        for (int i = 0; i < m; ++i) {\n            for (int j = 0; j < n; ++j) {\n                if (grid[i][j] == 1) {\n                    ans += (rows[i] - 1) * (cols[j] - 1);\n                }\n            }\n        }\n        return ans;\n    }\n};\n```\n\n#### Go\n\n```go\nfunc numberOfRightTriangles(grid [][]int) (ans int64) {\n\tm, n := len(grid), len(grid[0])\n\trows := make([]int, m)\n\tcols := make([]int, n)\n\tfor i, row := range grid {\n\t\tfor j, x := range row {\n\t\t\trows[i] += x\n\t\t\tcols[j] += x\n\t\t}\n\t}\n\tfor i, row := range grid {\n\t\tfor j, x := range row {\n\t\t\tif x == 1 {\n\t\t\t\tans += int64((rows[i] - 1) * (cols[j] - 1))\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n```\n\n#### TypeScript\n\n```ts\nfunction numberOfRightTriangles(grid: number[][]): number {\n    const m = grid.length;\n    const n = grid[0].length;\n    const rows: number[] = Array(m).fill(0);\n    const cols: number[] = Array(n).fill(0);\n    for (let i = 0; i < m; ++i) {\n        for (let j = 0; j < n; ++j) {\n            rows[i] += grid[i][j];\n            cols[j] += grid[i][j];\n        }\n    }\n    let ans = 0;\n    for (let i = 0; i < m; ++i) {\n        for (let j = 0; j < n; ++j) {\n            if (grid[i][j] === 1) {\n                ans += (rows[i] - 1) * (cols[j] - 1);\n            }\n        }\n    }\n    return ans;\n}\n```\n\n<!-- tabs:end -->\n\n<!-- solution:end -->","code":{"python":{"label":"Python","language":"python","code":"class Solution:\n    def numberOfRightTriangles(self, grid: List[List[int]]) -> int:\n        rows = [0] * len(grid)\n        cols = [0] * len(grid[0])\n        for i, row in enumerate(grid):\n            for j, x in enumerate(row):\n                rows[i] += x\n                cols[j] += x\n        ans = 0\n        for i, row in enumerate(grid):\n            for j, x in enumerate(row):\n                if x:\n                    ans += (rows[i] - 1) * (cols[j] - 1)\n        return ans"},"go":{"label":"Go","language":"go","code":"func numberOfRightTriangles(grid [][]int) (ans int64) {\n\tm, n := len(grid), len(grid[0])\n\trows := make([]int, m)\n\tcols := make([]int, n)\n\tfor i, row := range grid {\n\t\tfor j, x := range row {\n\t\t\trows[i] += x\n\t\t\tcols[j] += x\n\t\t}\n\t}\n\tfor i, row := range grid {\n\t\tfor j, x := range row {\n\t\t\tif x == 1 {\n\t\t\t\tans += int64((rows[i] - 1) * (cols[j] - 1))\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}"},"java":{"label":"Java","language":"java","code":"class Solution {\n    public long numberOfRightTriangles(int[][] grid) {\n        int m = grid.length, n = grid[0].length;\n        int[] rows = new int[m];\n        int[] cols = new int[n];\n        for (int i = 0; i < m; ++i) {\n            for (int j = 0; j < n; ++j) {\n                rows[i] += grid[i][j];\n                cols[j] += grid[i][j];\n            }\n        }\n        long ans = 0;\n        for (int i = 0; i < m; ++i) {\n            for (int j = 0; j < n; ++j) {\n                if (grid[i][j] == 1) {\n                    ans += (rows[i] - 1) * (cols[j] - 1);\n                }\n            }\n        }\n        return ans;\n    }\n}"},"cpp":{"label":"C++","language":"cpp","code":"class Solution {\npublic:\n    long long numberOfRightTriangles(vector<vector<int>>& grid) {\n        int m = grid.size(), n = grid[0].size();\n        vector<int> rows(m);\n        vector<int> cols(n);\n        for (int i = 0; i < m; ++i) {\n            for (int j = 0; j < n; ++j) {\n                rows[i] += grid[i][j];\n                cols[j] += grid[i][j];\n            }\n        }\n        long long ans = 0;\n        for (int i = 0; i < m; ++i) {\n            for (int j = 0; j < n; ++j) {\n                if (grid[i][j] == 1) {\n                    ans += (rows[i] - 1) * (cols[j] - 1);\n                }\n            }\n        }\n        return ans;\n    }\n};"},"typescript":{"label":"TypeScript","language":"ts","code":"function numberOfRightTriangles(grid: number[][]): number {\n    const m = grid.length;\n    const n = grid[0].length;\n    const rows: number[] = Array(m).fill(0);\n    const cols: number[] = Array(n).fill(0);\n    for (let i = 0; i < m; ++i) {\n        for (let j = 0; j < n; ++j) {\n            rows[i] += grid[i][j];\n            cols[j] += grid[i][j];\n        }\n    }\n    let ans = 0;\n    for (let i = 0; i < m; ++i) {\n        for (let j = 0; j < n; ++j) {\n            if (grid[i][j] === 1) {\n                ans += (rows[i] - 1) * (cols[j] - 1);\n            }\n        }\n    }\n    return ans;\n}"}},"sourcePath":"leetcode-main/solution/3100-3199/3128.Right Triangles"}
